{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/admin/?",
      "dest": "/admin/index.php"
    },
    {
      "src": "/admin/(.*)\\.php",
      "dest": "/admin/$1.php"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
